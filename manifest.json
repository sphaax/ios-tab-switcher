{
  "manifest_version": 3,
  "name": "iOS Tab Switcher",
  "version": "0.1.0",
  "description": "Le tab switcher de Chrome iOS, sur desktop : grille de cartes avec aperçus en direct de vos onglets.",
  "permissions": ["tabs", "storage", "favicon", "tabGroups"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Ouvrir le tab switcher"
  },
  "commands": {
    "open-switcher": {
      "suggested_key": {
        "default": "Ctrl+Shift+Space",
        "mac": "MacCtrl+Shift+Space"
      },
      "description": "Ouvrir le tab switcher"
    }
  }
}
